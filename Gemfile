source "https://rubygems.org"

# GitHub Pages builds your site with this gem; it pins Jekyll to the version
# GitHub uses so local previews match production.
gem "github-pages", group: :jekyll_plugins

# Windows and JRuby helpers (harmless on macOS/Linux)
gem "tzinfo-data", platforms: [:mingw, :mswin, :x64_mingw, :jruby]
gem "wdm", "~> 0.1.1", platforms: [:mingw, :mswin, :x64_mingw]
